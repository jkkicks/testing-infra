# Copy to `.env` and fill in. Never commit `.env`.
#
# Proxmox API (homelab)
PVE1_URL=https://10.0.0.201:8006/
PVE1_TOKEN_ID=root@pam!your-token-name
PVE1_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSH key for snippet uploads (Terraform cannot use your interactive root password).
# Point at the same key whose pubkey you installed on Proxmox root — see README "SSH auth".
# PVE1_SSH_PRIVATE_KEY_FILE=~/.ssh/id_ed25519
